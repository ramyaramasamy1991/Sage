# ── AWS / Bedrock ────────────────────────────────────────────────────────────
# Region where you've enabled Bedrock + Claude model access.
AWS_REGION=us-east-1

# Credentials: leave these unset to use your default AWS profile / IAM role
# (recommended). Set them only for quick local testing.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Bedrock model id. Newer Claude models on Bedrock are accessed via a
# cross-region inference profile (note the "us." region prefix). Confirm the
# exact id for your account in the Bedrock console → Model access / Inference.
# Examples:
#   us.anthropic.claude-opus-4-8
#   us.anthropic.claude-sonnet-4-6
BEDROCK_MODEL_ID=us.anthropic.claude-opus-4-8

# ── RAG / Knowledge Base ─────────────────────────────────────────────────────
# Your Bedrock Knowledge Base id (e.g. ABCD1234). Leave empty to run the bot
# without retrieval (it will answer from the model's own knowledge).
KNOWLEDGE_BASE_ID=
# How many passages to retrieve per question.
RAG_TOP_K=5
# Drop retrieved passages scoring below this (0 = keep all).
RAG_MIN_SCORE=0.0

# ── Generation ───────────────────────────────────────────────────────────────
MAX_TOKENS=4096
# Set to true to enable Claude's adaptive thinking (higher quality, more
# latency before the first token). Off by default for a snappy chat feel.
ENABLE_THINKING=false

# ── Auth ─────────────────────────────────────────────────────────────────────
# If set, /api/chat and /api/reset require this value in the X-API-Key header.
# Leave empty for open local dev.
API_KEY=

# ── Persistence ──────────────────────────────────────────────────────────────
# Set a Redis URL to persist/share session memory; empty = in-process memory.
REDIS_URL=
# Conversation turns kept per session (a turn = user + assistant).
MAX_TURNS=12

# ── App ──────────────────────────────────────────────────────────────────────
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=INFO
